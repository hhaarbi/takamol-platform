# ============================================================
# تكامل — Real Estate Management Platform
# Environment Variables Reference
# ============================================================
# انسخ هذا الملف إلى .env وعبّئ القيم الحقيقية:
#   cp env.example .env && nano .env
#
# ⚠️  لا ترفع ملف .env إلى GitHub أبداً!
# ============================================================

# ─── Node ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── App URL (Required in production) ─────────────────────────
# Set to your actual domain. Used for CORS, cookies, and redirects.
APP_URL=https://YOUR_DOMAIN

# Optional: override CORS origin if frontend is on a different domain
# CORS_ORIGIN=https://app.YOUR_DOMAIN

# ─── Database (MySQL 8.0+ / MariaDB 10.6+) ────────────────────
# Format: mysql://user:password@host:port/dbname
# Credentials are printed by setup-vps.sh
DATABASE_URL=mysql://realestate_user:STRONG_PASSWORD@127.0.0.1:3306/realestate_db

# ─── Session Security ──────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# JWT token expiry (optional, defaults: 15m access / 30d refresh)
# JWT_ACCESS_EXPIRES=15m
# JWT_REFRESH_EXPIRES=30d

# ─── Email System ──────────────────────────────────────────────
# Option A: Resend (recommended — https://resend.com)
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@YOUR_DOMAIN
EMAIL_FROM_NAME=تكامل لإدارة الأملاك

# Option B: SMTP (Zoho, Gmail, custom)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@YOUR_DOMAIN
# SMTP_PASS=your-smtp-password

# ─── OTP Settings ──────────────────────────────────────────────
# OTP expiry in minutes (default: 5)
OTP_EXPIRES_MINUTES=5
# Max OTP attempts before lockout (default: 3)
OTP_MAX_ATTEMPTS=3
# Rate limit: max OTPs per window (default: 3 per 15 minutes)
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MINUTES=15

# ─── Telegram Bot (Optional) ──────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (get from @userinfobot)
TELEGRAM_OWNER_CHAT_ID=

# ─── Owner Info ────────────────────────────────────────────────
OWNER_NAME=Admin

# ─── LLM / AI (Optional) ──────────────────────────────────────
# Compatible with OpenAI API and any OpenAI-compatible endpoint
# Examples:
#   OpenAI:       OPENAI_BASE_URL=https://api.openai.com/v1
#   Groq:         OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   Azure OpenAI: OPENAI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT
#   Local Ollama: OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── File Storage ──────────────────────────────────────────────
# STORAGE_PROVIDER: "local" | "s3" | "r2"
# "local" stores files in ./uploads/ (development only — NOT for production)
STORAGE_PROVIDER=local

# AWS S3 (if STORAGE_PROVIDER=s3)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_BUCKET=your-bucket-name
# AWS_REGION=me-south-1

# Cloudflare R2 (if STORAGE_PROVIDER=r2) — cheaper for MENA region
# S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# S3_ACCESS_KEY=your-r2-access-key
# S3_SECRET_KEY=your-r2-secret-key
# S3_BUCKET=your-r2-bucket-name
# S3_REGION=auto

# ─── App Branding ──────────────────────────────────────────────
VITE_APP_TITLE=تكامل لإدارة الأملاك
VITE_APP_LOGO=

# ─── Analytics (Optional — self-hosted Plausible or Umami) ────
# VITE_ANALYTICS_ENDPOINT=https://analytics.YOUR_DOMAIN
# VITE_ANALYTICS_WEBSITE_ID=your-site-id

# ─── Manus Platform (Leave empty on your own VPS) ─────────────
# These are only needed when running inside Manus hosting.
# On Contabo VPS, leave all of these empty or remove them.
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
