# ============================================================
# Real Estate Bot (تكامل) — Environment Variables Reference
# ============================================================
# انسخ هذا الملف إلى .env وعبّئ القيم الحقيقية:
#   cp env.example .env
#   nano .env
#
# ⚠️  لا ترفع ملف .env إلى GitHub أبداً!
# ============================================================

# ─── قاعدة البيانات ───────────────────────────────────────
# MySQL 8.0+ أو MariaDB 10.6+
# مثال محلي:   mysql://realestate_user:password@localhost:3306/realestate_db
# مثال سحابي:  mysql://user:pass@db.example.com:3306/realestate_db
DATABASE_URL="mysql://realestate_user:your_strong_password@localhost:3306/realestate_db"

# ─── الأمان ───────────────────────────────────────────────
# مفتاح تشفير JWT — يجب أن يكون عشوائياً وطويلاً (32+ حرف)
# لتوليد مفتاح عشوائي: openssl rand -base64 32
JWT_SECRET="change-this-to-a-very-long-random-secret-key-at-least-32-chars"

# ─── التطبيق ──────────────────────────────────────────────
NODE_ENV="production"
PORT=3000

# رابط التطبيق الكامل (بدون / في النهاية)
# يُستخدم في: CORS، cookies، OAuth redirects
APP_URL="https://yourdomain.com"

# ─── الذكاء الاصطناعي (LLM) ───────────────────────────────
# الخيار 1: OpenAI مباشرة (مستقل تماماً — موصى به)
OPENAI_API_KEY="sk-proj-..."
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# الخيار 2: OpenAI-compatible API (مثل Groq, Azure OpenAI)
# OPENAI_API_KEY="your-api-key"
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"
# OPENAI_MODEL="llama-3.3-70b-versatile"

# الخيار 3: Manus Forge (إذا كنت على منصة Manus فقط)
# BUILT_IN_FORGE_API_URL="https://forge.manus.im"
# BUILT_IN_FORGE_API_KEY="your-forge-key"
# VITE_FRONTEND_FORGE_API_KEY="your-frontend-key"
# VITE_FRONTEND_FORGE_API_URL="https://forge.manus.im"

# ─── التخزين (ملفات ومرفقات) ─────────────────────────────
# الخيار 1: AWS S3 (موصى به للإنتاج)
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="me-south-1"
AWS_S3_BUCKET="realestate-files"
AWS_S3_PUBLIC_URL="https://realestate-files.s3.me-south-1.amazonaws.com"

# الخيار 2: Cloudflare R2 (أرخص وأسرع للمنطقة العربية)
# R2_ACCOUNT_ID="your-account-id"
# R2_ACCESS_KEY_ID="your-r2-access-key"
# R2_SECRET_ACCESS_KEY="your-r2-secret"
# R2_BUCKET="realestate-files"
# R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
# R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ─── التنبيهات (Telegram Bot) ────────────────────────────
# للحصول على Token: تحدث مع @BotFather على Telegram
# للحصول على Chat ID: تحدث مع @userinfobot
TELEGRAM_BOT_TOKEN="123456789:AAF_your_bot_token_here"
TELEGRAM_OWNER_CHAT_ID="123456789"

# ─── المصادقة (Authentication) ────────────────────────────
# الخيار 1: Manus OAuth (إذا كنت على منصة Manus)
VITE_APP_ID=""
OAUTH_SERVER_URL="https://api.manus.im"
VITE_OAUTH_PORTAL_URL="https://auth.manus.im"
OWNER_OPEN_ID=""
OWNER_NAME=""

# الخيار 2: Local Auth (مستقل — يعمل بـ JWT_SECRET فقط)
# لا يحتاج إعداد إضافي، يعمل تلقائياً عند ترك VITE_APP_ID فارغاً

# ─── Analytics (اختياري) ─────────────────────────────────
# Plausible Analytics أو Umami (self-hosted)
VITE_ANALYTICS_ENDPOINT=""
VITE_ANALYTICS_WEBSITE_ID=""

# ─── معلومات التطبيق ─────────────────────────────────────
VITE_APP_TITLE="تكامل لإدارة الأملاك"
VITE_APP_LOGO=""
